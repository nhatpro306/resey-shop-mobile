# Copy to .env and fill in. These are PUBLIC client values only (anon key).
# NEVER put the Supabase service-role key or any server secret here.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
EXPO_PUBLIC_SENTRY_DSN=
# Web app base URL — used to load product images stored as relative paths (e.g. /products/x.jpg)
EXPO_PUBLIC_WEB_URL=https://your-web-app.vercel.app
